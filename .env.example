# Copy this to .env.local and fill in your keys
# Only OPENROUTER_API_KEY is required — others are optional

OPENROUTER_API_KEY=sk-or-...
SERP_API_KEY=your-serpapi-key
JSEARCH_KEY=your-rapidapi-key

# Clerk Auth (required for user tracking)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Razorpay Payments (required for token purchases)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Upstash Redis (required for server-side token tracking)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Sentry Error Monitoring (get DSN from sentry.io)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
SENTRY_ORG=midasmatch
SENTRY_PROJECT=javascript-nextjs

# =============================================================================
# MIDAS FEATURE FLAGS — Advanced Pre-Filter System
# =============================================================================
# Master switch — if false, ALL filter sub-flags are forced off (safe default)
NEXT_PUBLIC_FF_ADVANCED_FILTERS=false

# Individual filter sub-flags (only active when master switch is true)
NEXT_PUBLIC_FF_SALARY_FILTER=false
NEXT_PUBLIC_FF_COMPANY_SIZE_FILTER=false
NEXT_PUBLIC_FF_MULTI_REGION=false

# Admin user ID(s) for /api/admin/flags route (Clerk user ID)
ADMIN_USER_ID=user_xxxx
# ADMIN_USER_IDS=user_xxxx,user_yyyy  # comma-separated for multiple admins
