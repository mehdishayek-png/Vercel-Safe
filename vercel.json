{
    "framework": "nextjs",
    "buildCommand": "npm run build",
    "installCommand": "npm install",
    "devCommand": "npm run dev",
    "crons": [
        {
            "path": "/api/cron/scan-jobs",
            "schedule": "0 6 * * *"
        },
        {
            "path": "/api/cron/send-alerts",
            "schedule": "0 7 * * *"
        }
    ]
}
